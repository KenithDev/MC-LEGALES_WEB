---
import CircularButton from '../ui/CircularButton.astro';
---

<section class="relative w-full h-[85vh] min-h-[600px] overflow-hidden bg-mc-dark group" id="hero-nosotros">
  <!-- Reveal mask (curtain) -->
  <div class="absolute inset-0 z-30 bg-mc-dark origin-right data-reveal-mask"></div>

  <!-- Full-bleed background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/nosotros/HeroNosotros.webp" 
      alt="Equipo de Mercado & Competencia" 
      class="w-full h-full object-cover object-center data-parallax-img"
    />
  </div>

  <!-- Dark gradient for readability -->
  <div class="absolute inset-0 z-10 pointer-events-none bg-gradient-to-t from-mc-dark/90 via-mc-dark/50 to-transparent lg:bg-gradient-to-r lg:from-mc-dark/95 lg:via-mc-dark/70 lg:to-transparent"></div>

  <!-- Overlaid content -->
  <div class="relative z-20 container mx-auto px-6 md:px-12 h-full flex flex-col justify-end pb-10 md:pb-16">
    <div class="max-w-4xl">
      <h1 class="font-display font-light text-4xl md:text-5xl lg:text-[4.5rem] text-white mb-10 leading-[1.2] lg:leading-[1.15] tracking-tight">
        <span class="block overflow-hidden pb-2"><span class="block data-split-text" style="transition-delay: 700ms;">Un equipo de profesionales</span></span>
        <span class="block overflow-hidden pb-2"><span class="block data-split-text" style="transition-delay: 800ms;">disruptivos</span></span>
      </h1>
      
      <div class="overflow-hidden mb-10">
        <p class="text-white/90 text-[16px] md:text-[18px] max-w-4xl leading-[1.8] text-pretty data-fade-up" style="transition-delay: 950ms;">
          Contamos con un elevado compromiso ético y sentido de innovación permanente, capaces de brindar soluciones proactivas y eficientes, mediante una asesoría integral que se caracteriza por brindar respuestas anticipadas y directas, explicadas en un lenguaje sencillo y comprensible que resulte cercano a la necesidad de nuestros clientes.
        </p>
      </div>

      <div class="data-fade-up" style="transition-delay: 1100ms;">
        <CircularButton href="/staff" light>VER STAFF DE PROFESIONALES</CircularButton>
      </div>
    </div>
  </div>
</section>

<style>
  .data-reveal-mask {
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mask-active {
    transform: scaleX(0);
  }

  .data-split-text {
    transform: translateY(100%);
    opacity: 0;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1), opacity 600ms ease-out;
  }
  .split-text-active {
    transform: translateY(0);
    opacity: 1;
  }

  .data-fade-up {
    transform: translateY(24px);
    opacity: 0;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1), opacity 600ms ease-out;
  }
  .fade-up-active {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script>
  const initHeroNosotros = () => {
    setTimeout(() => {
      document.querySelector('.data-reveal-mask')?.classList.add('mask-active');
      document.querySelectorAll('.data-split-text').forEach(el => el.classList.add('split-text-active'));
      document.querySelectorAll('.data-fade-up').forEach(el => el.classList.add('fade-up-active'));
    }, 100);

    // Subtle parallax
    const img = document.querySelector('.data-parallax-img');
    if (img && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        img.setAttribute('style', `transform: translateY(${scrolled * 0.3}px)`);
      });
    }
  };
  
  // Run on first load
  initHeroNosotros();
  
  // Run on view transitions
  document.addEventListener('astro:page-load', () => {
    initHeroNosotros();
  });
</script>
