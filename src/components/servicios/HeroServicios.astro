<section class="relative w-full h-[75vh] md:h-[85vh] min-h-125 md:min-h-150 overflow-hidden bg-mc-dark">
  <!-- Full-bleed background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/servicios/HeroServicios.webp" 
      alt="Servicios Mercado & Competencia" 
      class="w-full h-full object-cover object-center"
    />
  </div>

  <!-- Dark gradient for readability (left-to-right, bottom-to-top) -->
  <div class="absolute inset-0 z-10 pointer-events-none bg-linear-to-t from-mc-dark/95 via-mc-dark/60 to-transparent lg:bg-linear-to-r lg:from-mc-dark/95 lg:via-mc-dark/70 lg:to-transparent"></div>

  <!-- Overlaid content, bottom-left -->
  <div class="relative z-20 container mx-auto px-6 md:px-12 h-full flex flex-col justify-end pb-16 md:pb-24">
    <div class="max-w-4xl">
      <p class="text-white/80 text-[13px] md:text-sm uppercase tracking-[0.2em] mb-4 md:mb-5 font-medium animate-fade-in-up">
        BIENVENIDOS A MERCADO & COMPETENCIA
      </p>
      <h1 class="font-display font-light text-4xl md:text-5xl lg:text-[4rem] text-white mb-8 md:mb-10 leading-[1.1] tracking-tight animate-fade-in-up" style="animation-delay: 50ms;">
        Asesoría legal<br />con visión de negocio
      </h1>

      <p class="text-white/90 text-base md:text-sm leading-relaxed md:leading-[1.8] max-w-3xl mb-10 md:mb-12 animate-fade-in-up" style="animation-delay: 100ms;">
        Más de una década asesorando a empresas líderes en el Perú, combinando rigor legal y sentido crítico empresarial. Descubre nuestras especialidades:
      </p>
      
      <div class="animate-fade-in-up" style="animation-delay: 150ms;">
        <a href="#especialidades" id="hero-scroll-cta" class="hero-scroll-cta group inline-flex items-center gap-4">
          <span class="hero-scroll-cta__circle relative flex items-center justify-center w-12 h-12 rounded-full border border-white transition-colors duration-300 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero-scroll-cta__icon text-white transition-colors duration-300"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </span>
          <span class="font-medium text-white transition-colors duration-300 group-hover:text-mc-primary">Ver especialidades</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(12px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll-down cue: bounces on its own to invite scrolling, then settles
     and nudges further down on hover instead of sliding sideways like the
     site's other circular buttons. */
  .hero-scroll-cta__icon {
    animation: hero-scroll-bounce 1.8s ease-in-out infinite;
  }
  .hero-scroll-cta:hover .hero-scroll-cta__circle {
    background: var(--color-mc-primary);
    border-color: var(--color-mc-primary);
  }
  .hero-scroll-cta:hover .hero-scroll-cta__icon {
    animation: none;
    transform: translateY(3px);
  }

  @keyframes hero-scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-cta__icon {
      animation: none;
    }
  }
</style>

<script>
  const scrollCta = document.getElementById('hero-scroll-cta');
  scrollCta?.addEventListener('click', (e) => {
    const target = document.getElementById('especialidades');
    if (!target) return;
    e.preventDefault();
    const y = target.getBoundingClientRect().top + window.scrollY - 100;
    window.scrollTo({ top: y, behavior: 'smooth' });
  });
</script>
