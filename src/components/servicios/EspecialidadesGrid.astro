---
const especialidades = [
  {
    title: "Protección al Consumidor",
    image: "/images/servicios/ProtecciondeConsumidor.webp",
    link: "/especialidades/proteccion-al-consumidor"
  },
  {
    title: "Regulación Publicitaria y Competencia Desleal",
    image: "/images/servicios/regulacionPublicitaria.webp",
    link: "/especialidades/regulacion-publicitaria"
  },
  {
    title: "Derecho Laboral y Migratorio",
    image: "/images/servicios/Derecho Laboral.webp",
    link: "/especialidades/derecho-laboral"
  },
  {
    title: "Derecho Empresarial",
    image: "/images/servicios/Derecho Empresarial.webp",
    link: "/especialidades/derecho-empresarial"
  },
  {
    title: "Litigios y Controversias",
    image: "/images/servicios/Litigio y Controversia.webp",
    link: "/especialidades/litigio-y-controversia"
  },
  {
    title: "Protección de Datos Personales (ODP)",
    image: "/images/servicios/Proteccion de Datos Personales.webp",
    link: "/especialidades/proteccion-de-datos"
  },
  {
    title: "Propiedad Intelectual",
    image: "/images/servicios/Propiedad Intelectual.webp",
    link: "/especialidades/propiedad-intelectual"
  },
  {
    title: "Derecho de Seguros",
    image: "/images/servicios/DerechodeSeguros.webp",
    link: "/especialidades/derecho-de-seguros"
  },
  {
    title: "Derecho Civil",
    image: "/images/servicios/DerechoCivil.webp",
    link: "/especialidades/derecho-civil"
  },
  {
    title: "Derecho Inmobiliario",
    image: "/images/servicios/Derecho Inmobiliario.webp",
    link: "/especialidades/derecho-inmobiliario"
  },
  {
    title: "Derecho Administrativo",
    image: "/images/servicios/derechoadministrativo.webp",
    link: "/especialidades/derecho-administrativo"
  },
  {
    title: "Derecho Concursal",
    image: "/images/servicios/Derecho Concursal.webp",
    link: "/especialidades/derecho-concursal"
  },
  {
    title: "Derecho Penal",
    image: "/images/servicios/DerechoPenal.webp",
    link: "/especialidades/derecho-penal"
  },
  {
    title: "Justicia Militar Policial",
    image: "/images/servicios/Justicia Militar Policial.webp",
    link: "/especialidades/justicia-militar"
  }
];
---

<section class="bg-mc-light py-20 md:py-32" id="especialidades">
  <div class="container mx-auto px-6 md:px-12">
    <h2 class="font-display font-semibold text-3xl md:text-4xl text-mc-dark mb-16 md:mb-20" data-reveal="fade-up">
      Nuestras especialidades
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-x-8 md:gap-y-12">
      {especialidades.map((esp, index) => (
        <a href={esp.link} class="group block cursor-pointer" data-reveal="soft-pop" style={`transition-delay: ${index * 80}ms;`}>
          <!-- Card -->
          <div class="w-full aspect-4/5 bg-white overflow-hidden mb-6 rounded-sm shadow-sm">
            <img 
              src={esp.image} 
              alt={esp.title} 
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05] will-change-transform"
              loading="lazy"
            />
          </div>
          
          <!-- Content below -->
          <div>
            <h3 class="text-mc-dark font-semibold text-[15px] md:text-base tracking-wide mb-3 transition-colors duration-300 group-hover:text-mc-primary">
              {esp.title}
            </h3>
            <!-- Animated orange line -->
            <div class="h-0.5 bg-mc-primary w-6 transition-all duration-300 ease-out group-hover:w-full"></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  [data-reveal="fade-up"] {
    opacity: 0;
    transform: translateY(24px);
    transition-property: opacity, transform;
    transition-duration: 700ms;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  [data-reveal="soft-pop"] {
    opacity: 0;
    transform: translateY(20px) scale(0.96);
    transition-property: opacity, transform;
    transition-duration: 700ms;
    transition-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .reveal-active {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }
</style>

<script>
  const observeGrid = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal-active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-reveal="fade-up"], [data-reveal="soft-pop"]').forEach(el => observer.observe(el));
  };

  observeGrid();
</script>
