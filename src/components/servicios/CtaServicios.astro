---
import Button from '../ui/Button.astro';
import CircularButton from '../ui/CircularButton.astro';
---

<section class="py-20 md:py-28 bg-white" id="cta-servicios">
  <div class="container mx-auto px-6 md:px-12">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-10">
      
      <!-- Text (Left) -->
      <div class="max-w-xl text-center lg:text-left">
        <h2 class="font-display font-light text-4xl md:text-[2.75rem] text-mc-dark mb-4 tracking-tight">
          ¿Necesitas asesoría legal?
        </h2>
        <p class="text-mc-medium text-[17px] md:text-lg leading-relaxed text-pretty">
          Habla con un especialista y encuentra la solución<br class="hidden md:block" /> que tu empresa necesita.
        </p>
      </div>

      <!-- Buttons (Right) -->
      <div class="flex flex-col sm:flex-row items-center gap-6 md:gap-10 shrink-0">
        <CircularButton href="/contacto">Habla con un especialista</CircularButton>
        <Button href="/" class="!text-[15px] !px-8 !py-3.5 !bg-mc-primary hover:!bg-mc-primary-hover text-white shadow-sm">
          Volver al inicio
        </Button>
      </div>
      
    </div>
  </div>
</section>
