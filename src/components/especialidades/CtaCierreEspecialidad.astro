---
import { buildWhatsAppLink } from '../../data/especialidades';

interface Props {
  title: string;
  heroImage: string;
  /** Optional background image for the CTA (falls back to heroImage) */
  ctaImage?: string;
}

const { title, heroImage, ctaImage } = Astro.props;
const bgImage = ctaImage ?? heroImage;
const whatsappLink = buildWhatsAppLink(title);
---

<section class="espec-cta-cierre">
  <!-- Background photo (reuses the hero image, different crop) -->
  <div class="espec-cta-cierre__bg" aria-hidden="true">
    <img
      src={bgImage}
      alt=""
      class="espec-cta-cierre__bg-img"
      loading="lazy"
    />
    <div class="espec-cta-cierre__overlay"></div>
  </div>

  <!-- Content -->
  <div class="espec-cta-cierre__inner">
    <h2 class="espec-cta-cierre__title">¿Tienes otra<br />consulta legal?</h2>

    <div class="espec-cta-cierre__actions">
      <!-- View all services -->
      <a href="/servicios" class="espec-cta-cierre__back-btn">
        <div class="espec-cta-cierre__back-circle">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </div>
        <span>Ver todos los servicios</span>
      </a>

      <!-- WhatsApp -->
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="espec-cta-cierre__wa-btn"
        id="espec-whatsapp-cta-cierre"
      >
        <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Escríbenos por WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .espec-cta-cierre {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background image — taller than the container to allow parallax range */
  .espec-cta-cierre__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .espec-cta-cierre__bg-img {
    width: 100%;
    height: 130%;         /* extra height = movement range */
    top: -15%;            /* initial centering */
    position: absolute;
    object-fit: cover;
    object-position: center center;
    display: block;
    will-change: transform;
  }
  .espec-cta-cierre__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(54,61,72,0.92) 0%,
      rgba(54,61,72,0.70) 60%,
      rgba(54,61,72,0.50) 100%
    );
  }

  /* Content */
  .espec-cta-cierre__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 72px 48px;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .espec-cta-cierre__title {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .espec-cta-cierre__actions {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  /* Back button: view all services */
  .espec-cta-cierre__back-btn {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .espec-cta-cierre__back-btn:hover { opacity: 0.75; }

  .espec-cta-cierre__back-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .espec-cta-cierre__back-btn:hover .espec-cta-cierre__back-circle {
    background: rgba(255,255,255,0.15);
    border-color: #fff;
  }

  /* WhatsApp button */
  .espec-cta-cierre__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    padding: 12px 22px;
    border-radius: 9999px;
    transition: filter 0.2s, transform 0.2s;
  }
  .espec-cta-cierre__wa-btn:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }
  .espec-cta-cierre__wa-btn svg {
    width: 18px;
    height: 18px;
    fill: #fff;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .espec-cta-cierre__inner {
      padding: 56px 24px;
    }
    .espec-cta-cierre__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector<HTMLElement>('.espec-cta-cierre');
    const img = section?.querySelector<HTMLElement>('.espec-cta-cierre__bg-img');
    if (!section || !img) return;

    // Disable parallax on mobile to avoid jank on small screens
    const mediaQuery = window.matchMedia('(max-width: 768px)');
    if (mediaQuery.matches) return;

    const STRENGTH = 60; // max offset in px, either direction
    let rafId: number;

    function updateParallax() {
      const rect = section!.getBoundingClientRect();
      const viewportH = window.innerHeight;

      // Progress: 1 when the section's top reaches the bottom of the viewport,
      //           0 when centered, -1 when the bottom exits at the top.
      const progress = (rect.top + rect.height / 2 - viewportH / 2) / viewportH;
      const clampedProgress = Math.max(-1, Math.min(1, progress));
      const translateY = clampedProgress * STRENGTH;

      img!.style.transform = `translateY(${translateY}px)`;
      rafId = 0;
    }

    function onScroll() {
      if (!rafId) {
        rafId = requestAnimationFrame(updateParallax);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    updateParallax();
  })();
</script>
