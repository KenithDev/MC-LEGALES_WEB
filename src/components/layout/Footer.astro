---

<footer class="bg-mc-primary text-white relative overflow-hidden pt-20 pb-8 px-6 md:px-12 mt-auto">
  <div class="container mx-auto">
    <!-- Top divider -->
    <hr class="border-white/30 mb-12" />

    <!-- Main content (4-column grid) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-12">

      <!-- Column 1: identity -->
      <div>
        <img src="/images/logos/logoMcWhite.webp" alt="Mercado & Competencia" class="w-16 md:w-24 h-auto mb-6" />
        <p class="text-sm font-light leading-relaxed mb-6">
          Damián Medina &amp; Asociados SCRL.<br />
          RUC: 20602980848
        </p>
        <a
          href="/libro-de-reclamaciones"
          aria-label="Ir al Libro de Reclamaciones"
          class="inline-flex items-center gap-3 bg-white rounded-lg p-2 pr-4 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg group w-fit"
        >
          <img src="/images/logos/book-claim-icon.webp" alt="" class="w-9 h-9 object-contain shrink-0" />
          <span class="text-mc-dark text-[11px] font-bold leading-tight uppercase tracking-wide group-hover:text-mc-primary transition-colors">
            Libro de<br />Reclamaciones
          </span>
        </a>
      </div>

      <!-- Column 2: legal -->
      <div>
        <h3 class="text-sm font-bold tracking-widest uppercase mb-6">LEGAL</h3>
        <ul class="space-y-4">
          <li><a href="/politica-de-cookies" class="text-sm font-light hover:underline underline-offset-4">Política de Cookies</a></li>
          <li><a href="/politicas-de-privacidad" class="text-sm font-light hover:underline underline-offset-4">Política de Privacidad</a></li>
          <li><a href="/terminos-y-condiciones" class="text-sm font-light hover:underline underline-offset-4">Términos y Condiciones</a></li>
        </ul>
      </div>

      <!-- Column 3: contact -->
      <div>
        <h3 class="text-sm font-bold tracking-widest uppercase mb-6">CONTACTO</h3>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 mt-6">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="shrink-0 text-white/80"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            <span class="text-sm font-light">(51) 987 208 575</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/80"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href="mailto:info@mclegales.com" class="text-sm font-light hover:underline underline-offset-4">info@mclegales.com</a>
          </li>
          <li class="flex items-start gap-3 mt-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-white/80"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-sm font-light leading-relaxed">
              Av. El Polo 401, Of. 303<br />
              Urb. El Derby de Monterrico<br />
              Santiago de Surco, Lima
            </span>
          </li>
        </ul>
      </div>

      <!-- Column 4: social media -->
      <div>
        <h3 class="text-sm font-bold tracking-widest uppercase mb-6">REDES SOCIALES</h3>
        <div class="flex gap-4">
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/mclegales/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-10 h-10 rounded-full border border-white flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-mc-primary hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <!-- YouTube -->
          <a href="https://www.youtube.com/@mercadocompetencia8630" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-10 h-10 rounded-full border border-white flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-mc-primary hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
          </a>
          <!-- Instagram -->
          <a href="https://www.instagram.com/mc.legales" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full border border-white flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-mc-primary hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <!-- TikTok -->
          <a href="https://www.tiktok.com/@mclegales" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-10 h-10 rounded-full border border-white flex items-center justify-center transition-all duration-200 hover:bg-white hover:text-mc-primary hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
          </a>
        </div>
      </div>
      
    </div>

    <!-- Bottom divider -->
    <hr class="border-white/30 mb-8" />

    <!-- Bottom bar: copyright -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] tracking-wider uppercase font-medium">
      <p>&copy; 2026 MERCADO & COMPETENCIA &middot; DAMIÁN MEDINA & ASOCIADOS SCRL.</p>
      <p>TODOS LOS DERECHOS RESERVADOS.</p>
    </div>
  </div>
</footer>
