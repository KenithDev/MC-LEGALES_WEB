---
import CircularButton from '../ui/CircularButton.astro';
---

<section class="relative w-full h-[60vh] md:h-[70vh] min-h-[400px] overflow-hidden bg-mc-dark">
  <!-- Full-bleed background image -->
  <div class="absolute inset-0 z-0">
    <!-- TODO: replace with a real group photo of the office -->
    <img
      src="/images/staff/HeroStaff (2).webp" 
      alt="Equipo Mercado & Competencia" 
      class="w-full h-full object-cover object-[center_20%]"
    />
  </div>

  <!-- Dark gradient for readability (left-to-right, bottom-to-top) -->
  <div class="absolute inset-0 z-10 pointer-events-none bg-gradient-to-t from-mc-dark/90 via-mc-dark/50 to-transparent lg:bg-gradient-to-r lg:from-mc-dark/90 lg:via-mc-dark/60 lg:to-transparent"></div>

  <!-- Overlaid content, bottom-left -->
  <div class="relative z-20 container mx-auto px-6 md:px-12 h-full flex flex-col justify-end pb-16 md:pb-24">
    <div class="max-w-3xl">
      <p class="text-white/80 text-[13px] md:text-sm uppercase tracking-[0.2em] mb-4 md:mb-5 font-medium animate-fade-in-up">
        CONOCE A NUESTRO EQUIPO
      </p>
      <h1 class="font-display font-light text-4xl md:text-5xl lg:text-[4rem] text-white mb-8 md:mb-10 leading-[1.1] tracking-tight animate-fade-in-up" style="animation-delay: 100ms;">
        Nuestros profesionales
      </h1>
      
      <div class="animate-fade-in-up" style="animation-delay: 200ms;">
        <CircularButton href="/servicios" light>Ver especialidades</CircularButton>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
    transform: translateY(16px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
