---
import '../styles/global.css';
import WhatsAppFloat from '../components/especialidades/WhatsAppFloat.astro';

interface Props {
  title: string;
  headerLight?: boolean;
  whatsappTitle?: string;
}

const { title, headerLight, whatsappTitle } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=Inter:wght@400;500;600&family=Kanit:wght@900&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body class="antialiased min-h-screen flex flex-col" data-header-light={headerLight ? 'true' : undefined}>
    <slot />
    
    <WhatsAppFloat specialtyTitle={whatsappTitle} />
  </body>
</html>
