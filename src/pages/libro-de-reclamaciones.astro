---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';

const steps = [
  { number: '01', title: 'Identificación del consumidor reclamante', desc: 'Cuéntanos quién eres para poder contactarte.' },
  { number: '02', title: 'Identificación del bien contratado', desc: 'Indícanos sobre qué producto o servicio nos escribes.' },
  { number: '03', title: 'Detalle de la reclamación y pedido', desc: 'Describe tu caso y qué solución esperas de nosotros.' },
];
---

<Layout title="Libro de Reclamaciones | Mercado & Competencia">
  <Header />

  <main class="flex-grow">
    <!-- ─── INTRO ─── -->
    <section class="bg-mc-dark relative overflow-hidden pt-36 pb-16 md:pt-48 md:pb-24">
      <div class="pointer-events-none absolute -right-24 -top-24 w-96 h-96 rounded-full bg-mc-primary/10 blur-3xl"></div>
      <div class="container mx-auto px-6 md:px-12 relative z-10">
        <div class="max-w-2xl">
          <p class="text-mc-primary text-xs font-bold uppercase tracking-[0.2em] mb-6 animate-fade-in-up">Atención al consumidor</p>
          <h1 class="font-display font-light text-4xl md:text-5xl text-white leading-[1.1] mb-5 tracking-tight animate-fade-in-up" style="animation-delay: 50ms;">
            Libro de Reclamaciones
          </h1>
          <p class="text-white/70 text-[15px] md:text-base leading-relaxed animate-fade-in-up" style="animation-delay: 100ms;">
            Damián Medina &amp; Asociados SCRL, con RUC: 20602980848, con domicilio fiscal en
            Pasaje Las Brisas 108, Distrito de La Victoria, Provincia y Departamento de Lima.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── FORM ─── -->
    <section class="bg-mc-light py-16 md:py-24">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

          <!-- Side stepper (desktop) -->
          <aside class="hidden lg:block lg:col-span-3 sticky top-28">
            <ul class="flex flex-col gap-10 pl-2">
              {steps.map((step, index) => (
                <li class="relative flex items-start gap-4" data-step-nav={index}>
                  {index < steps.length - 1 && (
                    <span class="absolute left-5 top-10 -bottom-10 w-px -translate-x-1/2 bg-mc-dark/10" aria-hidden="true"></span>
                  )}
                  <span class="relative z-10 shrink-0 w-10 h-10 rounded-full bg-white border-2 border-mc-dark/10 flex items-center justify-center text-sm font-bold text-mc-medium step-dot transition-colors duration-300">
                    {step.number}
                  </span>
                  <div class="pt-1.5">
                    <p class="text-mc-dark font-semibold text-[15px] leading-snug mb-1">{step.title}</p>
                    <p class="text-mc-medium text-xs leading-relaxed">{step.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </aside>

          <!-- Form -->
          <div class="lg:col-span-9">
            <form id="claim-form" class="flex flex-col gap-8" onsubmit="event.preventDefault();">

              <!-- SECTION 1 -->
              <div class="claim-card" id="step-0">
                <div class="claim-card__header">
                  <span class="claim-card__number">01</span>
                  <div>
                    <h2 class="claim-card__title">Identificación del consumidor reclamante</h2>
                    <p class="claim-card__subtitle">Tus datos de contacto para dar seguimiento a tu caso.</p>
                  </div>
                </div>

                <div class="claim-card__body">
                  <div class="form-group relative sm:col-span-2">
                    <label for="nombres" class="form-label">Nombres y apellidos <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <input type="text" id="nombres" name="nombres" required class="form-input" placeholder="Escribe tus nombres completos" />
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative">
                    <label for="documento" class="form-label">DNI / CE / RUC <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <input type="text" id="documento" name="documento" required class="form-input" placeholder="N.° de documento" />
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative">
                    <label for="telefono" class="form-label">Teléfono / Celular <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <input type="tel" id="telefono" name="telefono" required class="form-input" placeholder="+51 999 999 999" />
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative">
                    <label for="email" class="form-label">Correo electrónico <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <input type="email" id="email" name="email" required class="form-input" placeholder="ejemplo@correo.com" />
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative">
                    <label for="direccion" class="form-label">Dirección <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <input type="text" id="direccion" name="direccion" required class="form-input" placeholder="Av., calle, distrito..." />
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <label class="custom-checkbox flex items-start gap-3 cursor-pointer group sm:col-span-2 mt-1">
                    <div class="checkbox-box">
                      <input type="checkbox" id="menor-edad" name="menor-edad" class="peer sr-only" />
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="checkbox-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      <div class="checkbox-fill"></div>
                    </div>
                    <span class="text-sm text-mc-medium leading-relaxed select-none">Soy menor de edad</span>
                  </label>
                </div>
              </div>

              <!-- SECTION 2 -->
              <div class="claim-card" id="step-1">
                <div class="claim-card__header">
                  <span class="claim-card__number">02</span>
                  <div>
                    <h2 class="claim-card__title">Identificación del bien contratado</h2>
                    <p class="claim-card__subtitle">Cuéntanos sobre qué producto o servicio es tu caso.</p>
                  </div>
                </div>

                <div class="claim-card__body">
                  <div class="sm:col-span-2">
                    <span class="form-label block mb-3">Tipo de bien contratado <span class="text-mc-primary">*</span></span>
                    <div class="flex flex-wrap gap-3" role="radiogroup" aria-label="Tipo de bien contratado">
                      <label class="option-pill">
                        <input type="radio" name="tipo-bien" value="producto" class="sr-only" required />
                        <span class="option-pill__label">Producto</span>
                      </label>
                      <label class="option-pill">
                        <input type="radio" name="tipo-bien" value="servicio" class="sr-only" />
                        <span class="option-pill__label">Servicio</span>
                      </label>
                    </div>
                  </div>

                  <div class="form-group relative sm:col-span-2">
                    <label for="descripcion-bien" class="form-label">Descripción del producto o servicio <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <textarea id="descripcion-bien" name="descripcion-bien" rows="3" required class="form-input resize-y min-h-24" placeholder="Describe brevemente el producto o servicio contratado..."></textarea>
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative">
                    <label for="monto" class="form-label">Monto reclamado</label>
                    <div class="relative overflow-hidden rounded-md">
                      <span class="form-input-prefix">S/</span>
                      <input type="text" inputmode="decimal" id="monto" name="monto" class="form-input pl-10" placeholder="0.00" />
                      <div class="focus-line"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- SECTION 3 -->
              <div class="claim-card" id="step-2">
                <div class="claim-card__header">
                  <span class="claim-card__number">03</span>
                  <div>
                    <h2 class="claim-card__title">Detalle de la reclamación y pedido del consumidor</h2>
                    <p class="claim-card__subtitle">Explícanos qué ocurrió y qué solución esperas.</p>
                  </div>
                </div>

                <div class="claim-card__body">
                  <div class="sm:col-span-2">
                    <span class="form-label block mb-3">Tipo de solicitud <span class="text-mc-primary">*</span></span>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" role="radiogroup" aria-label="Tipo de solicitud">
                      <label class="claim-option">
                        <input type="radio" name="tipo-solicitud" value="reclamo" class="sr-only" required />
                        <div class="claim-option__card">
                          <span class="claim-option__radio" aria-hidden="true"></span>
                          <div>
                            <p class="claim-option__title">Reclamo</p>
                            <p class="claim-option__desc">Disconformidad relacionada a los productos y/o servicios.</p>
                          </div>
                        </div>
                      </label>
                      <label class="claim-option">
                        <input type="radio" name="tipo-solicitud" value="queja" class="sr-only" />
                        <div class="claim-option__card">
                          <span class="claim-option__radio" aria-hidden="true"></span>
                          <div>
                            <p class="claim-option__title">Queja</p>
                            <p class="claim-option__desc">Disconformidad no relacionada a los productos y/o servicios, o malestar en la atención al público.</p>
                          </div>
                        </div>
                      </label>
                    </div>
                  </div>

                  <div class="form-group relative sm:col-span-2">
                    <label for="detalle" class="form-label">Detalle de la reclamación <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <textarea id="detalle" name="detalle" rows="4" required class="form-input resize-y min-h-28" placeholder="Cuéntanos con el mayor detalle posible qué sucedió..."></textarea>
                      <div class="focus-line"></div>
                    </div>
                  </div>

                  <div class="form-group relative sm:col-span-2">
                    <label for="pedido" class="form-label">Pedido del consumidor <span class="text-mc-primary">*</span></label>
                    <div class="relative overflow-hidden rounded-md">
                      <textarea id="pedido" name="pedido" rows="3" required class="form-input resize-y min-h-24" placeholder="¿Qué solución esperas de nosotros?"></textarea>
                      <div class="focus-line"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- INFO NOTICE -->
              <div class="claim-notice">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="claim-notice__icon"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <ul class="claim-notice__list">
                  <li>La formulación del reclamo no impide acudir a otras vías de solución de controversias ni es requisito previo para interponer una denuncia ante el INDECOPI.</li>
                  <li>El proveedor debe dar respuesta al reclamo o queja en un plazo no mayor a quince (15) días hábiles, el cual es improrrogable.</li>
                </ul>
              </div>

              <!-- SUBMIT -->
              <div class="flex justify-end">
                <Button type="submit" class="w-full sm:w-auto gap-3 min-w-[180px] group relative overflow-hidden">
                  <span class="relative z-10 btn-text transition-opacity duration-200 inline-flex items-center gap-3">
                    Enviar
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                  </span>
                  <svg class="animate-spin h-5 w-5 text-white absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 btn-spinner transition-opacity duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </Button>
              </div>

              <!-- Success message -->
              <div class="success-message hidden bg-white p-5 rounded-md border-l-4 border-mc-primary shadow-sm">
                <p class="text-sm text-mc-dark font-medium">Tu reclamo ha sido registrado exitosamente. Te responderemos dentro del plazo legal establecido.</p>
              </div>

            </form>
          </div>

        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
    transform: translateY(16px);
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Section cards (stepper) ── */
  .claim-card {
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 1px 3px rgba(54, 61, 72, 0.06);
    border: 1px solid rgba(54, 61, 72, 0.06);
    padding: 1.75rem;
    scroll-margin-top: 140px;
  }
  @media (min-width: 768px) {
    .claim-card { padding: 2.25rem; }
  }

  .claim-card__header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #ECEAE8;
  }

  .claim-card__number {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: var(--color-mc-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .claim-card__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--color-mc-dark);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .claim-card__subtitle {
    font-size: 0.825rem;
    color: var(--color-mc-medium);
  }

  .claim-card__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .claim-card__body { grid-template-columns: 1fr 1fr; }
  }

  /* ── Inputs ── */
  .form-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-mc-dark);
    margin-bottom: 0.4rem;
  }
  .form-input {
    width: 100%;
    background: var(--color-mc-light);
    color: var(--color-mc-dark);
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    outline: none;
    border: 1px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }
  .form-input::placeholder { color: var(--color-mc-soft); }
  .form-input:focus { background: #fff; border-color: rgba(242, 107, 65, 0.35); }
  .form-input-prefix {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-mc-medium);
    font-size: 14px;
    font-weight: 600;
    pointer-events: none;
  }
  .focus-line {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 100%;
    background: var(--color-mc-primary);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.3s ease-out;
  }
  .form-input:focus + .focus-line { transform: scaleX(1); }
  .form-group:focus-within .form-label { color: var(--color-mc-primary-deep); }

  /* ── Checkbox: "Soy menor de edad" ── */
  .checkbox-box {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.125rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-mc-medium);
    background: #fff;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .group:hover .checkbox-box { border-color: var(--color-mc-primary); }
  .checkbox-icon {
    position: absolute;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.2s ease-out;
    z-index: 10;
  }
  .checkbox-fill {
    position: absolute;
    inset: 0;
    background: var(--color-mc-primary);
    transform: scale(0);
    opacity: 0;
    transition: all 0.2s;
    border-radius: 3px;
  }
  input:checked ~ .checkbox-icon,
  input:checked + .checkbox-icon { opacity: 1; transform: scale(1); }
  input:checked ~ .checkbox-fill { transform: scale(1); opacity: 1; }

  /* ── Pills (Producto / Servicio) ── */
  .option-pill { cursor: pointer; }
  .option-pill__label {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: 9999px;
    border: 1.5px solid #DADDE1;
    color: var(--color-mc-medium);
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .option-pill:hover .option-pill__label { border-color: var(--color-mc-primary); color: var(--color-mc-dark); }
  .option-pill input:checked + .option-pill__label {
    background: var(--color-mc-dark);
    border-color: var(--color-mc-dark);
    color: #fff;
  }

  /* ── Selectable cards (Reclamo / Queja) ── */
  .claim-option { cursor: pointer; display: block; }
  .claim-option__card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.1rem 1.25rem;
    border: 1.5px solid #E5E7EB;
    border-radius: 0.75rem;
    background: #fff;
    height: 100%;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .claim-option:hover .claim-option__card { border-color: var(--color-mc-primary); transform: translateY(-1px); }
  .claim-option input:checked + .claim-option__card {
    border-color: var(--color-mc-primary);
    background: #FFF8F5;
  }
  .claim-option__radio {
    flex-shrink: 0;
    margin-top: 0.15rem;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 9999px;
    border: 2px solid #D1D5DB;
    position: relative;
    transition: border-color 0.2s;
  }
  .claim-option input:checked + .claim-option__card .claim-option__radio {
    border-color: var(--color-mc-primary);
  }
  .claim-option input:checked + .claim-option__card .claim-option__radio::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 9999px;
    background: var(--color-mc-primary);
  }
  .claim-option__title { font-weight: 600; color: var(--color-mc-dark); font-size: 14.5px; margin-bottom: 0.2rem; }
  .claim-option__desc { font-size: 12.5px; color: var(--color-mc-medium); line-height: 1.5; }

  /* ── Info notice ── */
  .claim-notice {
    display: flex;
    gap: 1rem;
    background: var(--color-mc-light);
    border-left: 3px solid var(--color-mc-primary);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1.25rem 1.5rem;
  }
  .claim-notice__icon {
    flex-shrink: 0;
    color: var(--color-mc-primary);
    margin-top: 0.15rem;
  }
  .claim-notice__list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 13px;
    color: var(--color-mc-medium);
    line-height: 1.6;
    list-style: disc;
    padding-left: 1.1rem;
  }

  /* ── Side stepper: active state ── */
  .step-dot.is-active {
    background: var(--color-mc-primary);
    border-color: var(--color-mc-primary);
    color: #fff;
  }
</style>

<script>
  const form = document.getElementById('claim-form') as HTMLFormElement;
  const submitBtn = form?.querySelector('button[type="submit"]');
  const btnText = submitBtn?.querySelector('.btn-text');
  const btnSpinner = submitBtn?.querySelector('.btn-spinner');
  const successMsg = form?.querySelector('.success-message');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    btnText?.classList.add('opacity-0');
    btnSpinner?.classList.remove('opacity-0');

    fetch("https://formsubmit.co/ajax/odamian@mclegales.com", {
      method: "POST",
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    })
    .then(res => res.json())
    .then(() => {
      btnSpinner?.classList.add('opacity-0');
      btnText?.classList.remove('opacity-0');

      form.reset();
      document.querySelectorAll('.claim-option input, .option-pill input').forEach((el) => {
        (el as HTMLInputElement).checked = false;
      });
      successMsg?.classList.remove('hidden');
      successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });

      setTimeout(() => successMsg?.classList.add('hidden'), 6000);
    })
    .catch((err) => {
      console.error("Error al enviar el formulario", err);
      btnSpinner?.classList.add('opacity-0');
      btnText?.classList.remove('opacity-0');
      alert("Hubo un error al enviar tu mensaje. Por favor intenta más tarde.");
    });
  });

  // Highlight the active step in the side stepper based on scroll
  const stepDots = document.querySelectorAll('.step-dot');
  const stepSections = ['step-0', 'step-1', 'step-2'].map((id) => document.getElementById(id));

  if (stepDots.length && stepSections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = stepSections.findIndex((s) => s === entry.target);
            stepDots.forEach((dot, i) => dot.classList.toggle('is-active', i === index));
          }
        });
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
    );
    stepSections.forEach((s) => s && observer.observe(s));
  }
</script>
