---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

import HeroNosotros from '../components/nosotros/HeroNosotros.astro';
import Mision from '../components/nosotros/Mision.astro';
import Vision from '../components/nosotros/Vision.astro';
import Metrics from '../components/nosotros/Metrics.astro';
import Values from '../components/nosotros/Values.astro';
import CallToAction from '../components/sections/CallToAction.astro';
---
<Layout title="Nosotros | Mercado & Competencia">
  <Header />
  
  <main class="flex-grow">
    <HeroNosotros />
    <Mision />
    <Vision />
    <Metrics />
    <Values />
    <CallToAction />
  </main>
  
  <Footer />
</Layout>

<script>
  const observeNosotros = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if(entry.target.classList.contains('data-reveal-mask-scroll')) entry.target.classList.add('mask-active-scroll');
          if(entry.target.classList.contains('data-split-text-scroll')) entry.target.classList.add('split-text-active-scroll');
          if(entry.target.classList.contains('data-fade-up-scroll')) entry.target.classList.add('fade-up-active-scroll');
          if(entry.target.classList.contains('data-draw-in')) entry.target.classList.add('draw-in-active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.data-reveal-mask-scroll, .data-split-text-scroll, .data-fade-up-scroll, .data-draw-in').forEach(el => observer.observe(el));
    
    // Subtle parallax on the Mision/Vision images
    const parallaxImgs = document.querySelectorAll('.data-parallax-scroll');
    if (parallaxImgs.length > 0 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const onScroll = () => {
        parallaxImgs.forEach(img => {
          const rect = img.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            const centerOffset = (rect.top + rect.height/2) - (window.innerHeight/2);
            img.setAttribute('style', `transform: translateY(${centerOffset * 0.1}px) scale(1.1)`);
          }
        });
      };
      window.addEventListener('scroll', onScroll);
    }
  };
  
  // Run on first load
  observeNosotros();
  
  // Run on view transitions
  document.addEventListener('astro:page-load', () => {
    observeNosotros();
  });
</script>
