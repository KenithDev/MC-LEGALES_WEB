---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import ValueProposition from '../components/sections/ValueProposition.astro';
import DifferentialFactors from '../components/sections/DifferentialFactors.astro';
import Staff from '../components/sections/Staff.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import ContactForm from '../components/sections/ContactForm.astro';
---

